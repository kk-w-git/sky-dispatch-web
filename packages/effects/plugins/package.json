{
  "name": "@mamba/plugins",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./echarts": {
      "types": "./src/echarts/index.ts",
      "default": "./src/echarts/index.ts"
    },
    "./vxe-table": {
      "types": "./src/vxe-table/index.ts",
      "default": "./src/vxe-table/index.ts"
    },
    "./motion": {
      "types": "./src/motion/index.ts",
      "default": "./src/motion/index.ts"
    }
  },
  "dependencies": {
    "@mamba-core/design": "workspace:*",
    "@mamba-core/form-ui": "workspace:*",
    "@mamba-core/shadcn-ui": "workspace:*",
    "@mamba-core/shared": "workspace:*",
    "@mamba/hooks": "workspace:*",
    "@mamba/icons": "workspace:*",
    "@mamba/locales": "workspace:*",
    "@mamba/preferences": "workspace:*",
    "@mamba/types": "workspace:*",
    "@mamba/utils": "workspace:*",
    "@vueuse/core": "catalog:",
    "@vueuse/motion": "catalog:",
    "echarts": "catalog:",
    "vue": "catalog:",
    "vxe-pc-ui": "catalog:",
    "vxe-table": "catalog:"
  }
}
