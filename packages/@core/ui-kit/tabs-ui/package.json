{
  "name": "@mamba-core/tabs-ui",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm exec tsdown",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "production": "./src/index.ts",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "dependencies": {
    "@mamba-core/composables": "workspace:*",
    "@mamba-core/design": "workspace:*",
    "@mamba-core/icons": "workspace:*",
    "@mamba-core/shadcn-ui": "workspace:*",
    "@mamba-core/typings": "workspace:*",
    "@vueuse/core": "catalog:",
    "vue": "catalog:"
  }
}
