{
  "name": "@mamba-core/preferences",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "#build": "pnpm exec tsdown"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "production": "./src/index.ts",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "dependencies": {
    "@mamba-core/shared": "workspace:*",
    "@mamba-core/typings": "workspace:*",
    "@vueuse/core": "catalog:",
    "vue": "catalog:"
  }
}
